---
export const prerender = true;

import DocsHeader from '@/components/DocsHeader.astro';
import DocsSidebar from '@/components/DocsSidebar.astro';
import DocsTocWithErrorBoundary from '@/components/DocsTocWithErrorBoundary.tsx';
import DocsLayout from '@/layouts/DocsLayout.astro';
---

<DocsLayout title="KeyMesh Documentation" description="Lightweight, concurrency-safe credential orchestration runtime for AI API systems">
  <DocsHeader />

  <div class="flex">
    <DocsSidebar />

    <main class="flex-1 lg:pl-64 xl:pr-64">
      <div class="mx-auto max-w-4xl px-6 py-12 lg:px-8">
        <article class="prose prose-neutral dark:prose-invert max-w-none">
          <div class="mb-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold bg-primary/10 text-primary border border-primary/20 mb-4">
              <span>🗝️</span>
              <span>Lightweight Credential Pool Manager</span>
            </div>
            <h1 id="welcome" class="text-4xl sm:text-5xl font-extrabold tracking-tight text-balance mb-4">
              KeyMesh Documentation
            </h1>
            <p class="text-xl text-muted-foreground leading-relaxed">
              A concurrency-safe credential orchestration runtime for AI API systems. Multiplex multiple API keys across highly concurrent workloads to maximize aggregate throughput while maintaining full control over requests.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-12 not-prose">
            <div class="p-6 rounded-xl border border-border bg-card hover:shadow-md transition-all duration-300">
              <h3 class="text-lg font-bold flex items-center gap-2 mb-2 text-foreground">
                <span class="text-primary text-xl">🛡️</span>
                No Middleman (Zero Latency)
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                KeyMesh runs locally on your machine and does not intercept HTTP/API traffic. It only answers: <code class="px-1.5 py-0.5 rounded bg-muted text-xs">"Use this key next"</code>, adding absolute zero latency.
              </p>
            </div>
            
            <div class="p-6 rounded-xl border border-border bg-card hover:shadow-md transition-all duration-300">
              <h3 class="text-lg font-bold flex items-center gap-2 mb-2 text-foreground">
                <span class="text-primary text-xl">🔌</span>
                Works with Any Client
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                No custom API proxies or heavy SDK wrappers. Continue using standard, official clients like <code class="px-1.5 py-0.5 rounded bg-muted text-xs">openai</code>, <code class="px-1.5 py-0.5 rounded bg-muted text-xs">anthropic</code>, or raw HTTP clients.
              </p>
            </div>

            <div class="p-6 rounded-xl border border-border bg-card hover:shadow-md transition-all duration-300">
              <h3 class="text-lg font-bold flex items-center gap-2 mb-2 text-foreground">
                <span class="text-primary text-xl">🔄</span>
                Async & Thread-Safe
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                Designed for high-throughput, concurrent runtimes. KeyMesh uses state mutation locks to ensure key statistics, cooldown states, and workloads never suffer from race conditions.
              </p>
            </div>

            <div class="p-6 rounded-xl border border-border bg-card hover:shadow-md transition-all duration-300">
              <h3 class="text-lg font-bold flex items-center gap-2 mb-2 text-foreground">
                <span class="text-primary text-xl">⚡</span>
                Adaptive Schedulers
              </h3>
              <p class="text-sm text-muted-foreground leading-relaxed">
                Choose between strategies like Least Busy, Round Robin, or Weighted strategies. Automatically skips rate-limited keys on cooldown and logs latencies with Exponential Moving Average (EMA).
              </p>
            </div>
          </div>

          <section id="getting-started" class="mb-12">
            <h2 class="text-2xl font-bold tracking-tight mb-4 border-b pb-2">Getting Started</h2>
            <p class="text-base leading-relaxed mb-6">
              Ready to integrate KeyMesh into your Python codebase? Learn how to set up KeyPool, handle key lifecycles, and prevent race conditions:
            </p>
            <div class="flex flex-wrap gap-4 not-prose">
              <a href="/content/getting-started/welcome" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg text-sm font-semibold bg-primary text-primary-foreground hover:opacity-90 transition-opacity">
                Welcome Guide
              </a>
              <a href="/content/getting-started/quick-start" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg text-sm font-semibold border border-border bg-background hover:bg-muted text-foreground transition-colors">
                Quick Start
              </a>
            </div>
          </section>
        </article>
      </div>
    </main>

    <DocsTocWithErrorBoundary client:idle />
  </div>
</DocsLayout>
